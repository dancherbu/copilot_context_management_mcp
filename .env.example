COMPOSE_PROJECT_NAME=copilot-context-management-mcp
APP_PORT=18080
REDIS_PORT=16379
# Set this to the single repo or workspace root you want CCM to index.
# Do not point it at your entire home directory.
HOST_PROJECTS_DIR=/absolute/path/to/your/projects-or-repo
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
CCM_API_KEY=
REDIS_PASSWORD=replace-me
WORKSPACE_WATCH_ROOT=/workspace/projects
LOG_FILE_PATH=/app/logs/application.log
VECTOR_STORE_FILE=/app/data/vector-store.json
CCM_USAGE_METRICS_FILE=/app/data/usage-metrics.json
